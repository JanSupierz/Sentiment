def pokaz_wyniki_mcnemara(csv_path, p_threshold=0.05):
    try:
        df_results = pd.read_csv(csv_path)

        # Upewniamy się, że kolumny są traktowane jako liczby (float)
        df_results['P_Value'] = df_results['P_Value'].astype(float)
        df_results['Acc_Baseline'] = df_results['Acc_Baseline'].astype(float)
        df_results['Acc_Model'] = df_results['Acc_Model'].astype(float)

        # ==========================================
        # ZAAWANSOWANE SORTOWANIE (Dwie Grupy)
        # ==========================================
        mask_sig = df_results['P_Value'] < p_threshold
        df_sig = df_results[mask_sig].copy()
        df_nonsig = df_results[~mask_sig].copy()

        # Grupa 1: Istotne statystycznie (Sortujemy po Acc do 5 miejsc, potem alfabetycznie)
        if not df_sig.empty:
            df_sig['Acc_Model_sort'] = df_sig['Acc_Model'].round(5)
            df_sig = df_sig.sort_values(
                by=['Acc_Model_sort', 'Compared_Model'], 
                ascending=[False, True]
            ).drop(columns=['Acc_Model_sort'])

        # Grupa 2: Szum / Nieistotne (Sortujemy tylko alfabetycznie po nazwie)
        if not df_nonsig.empty:
            df_nonsig = df_nonsig.sort_values(by=['Compared_Model'], ascending=[True])

        # Łączymy grupy z powrotem (zwycięzcy zawsze na górze)
        df_results = pd.concat([df_sig, df_nonsig]).reset_index(drop=True)

        # ==========================================
        # STYLOWANIE
        # ==========================================
        def highlight_winner(row):
            css = pd.Series([''] * len(row), index=row.index)
            if row['P_Value'] < p_threshold:
                if row['Acc_Model'] > row['Acc_Baseline']:
                    css['Compared_Model'] = 'font-weight: bold; color: #1a73e8;'
                else:
                    css['Baseline'] = 'font-weight: bold; color: #1a73e8;'
            return css

        def color_p_value(val):
            if val < p_threshold:
                return 'background-color: #d4edda; color: #155724; font-weight: bold'
            return 'color: #721c24; font-style: italic'

        tytul = "Wyniki Testu McNemara"

        styled_df = (df_results.style
                     .apply(highlight_winner, axis=1)
                     .map(color_p_value, subset=['P_Value'])
                     .format({
                         "Acc_Baseline": "{:.2%}", 
                         "Acc_Model": "{:.2%}",
                         "P_Value": "{:.6f}"
                     })
                     .set_caption(tytul)
                     .set_table_styles([{'selector': 'caption', 'props': [('font-size', '16px'), ('font-weight', 'bold')]}]))

        display(styled_df)

    except FileNotFoundError:
        print(f"Nie znaleziono pliku: {csv_path}. Sprawdź ścieżkę.")
    except KeyError as e:
        print(f"Błąd! Plik CSV nie posiada wymaganej kolumny: {e}")


