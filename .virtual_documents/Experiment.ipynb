import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import matplotlib.lines as mlines
from pathlib import Path

def plot_ngram_results_polished(
    reports_dir="results/val/run_n_grams/classification_reports",
    mcnemar_csv_path="results/analysis/n_gram_mcnemar_raport.csv",
    baseline_dir="results/val/run_custom/classification_reports",
    baseline_prefix="tokens_lower_CustomTfidf_Z2"
):
    reports_path = Path(reports_dir)
    ngram_ranges = ["1-1", "1-2", "1-3"]
    models = {"linear_svm": "Linear SVM", "logreg": "Logistic Regression"}
    z_threshold = 2.0

    # 1. Load McNemar P-values with (Target, Baseline) pairs
    p_values = {}
    mcnemar_path = Path(mcnemar_csv_path)
    if mcnemar_path.exists():
        df_mc = pd.read_csv(mcnemar_path)
        for _, row in df_mc.iterrows():
            # Get compared model
            comp_col = 'Compared_Model' if 'Compared_Model' in df_mc.columns else 'Model_Porównywany'
            comp_name = row[comp_col]
            if ":::" in comp_name:
                comp_name = comp_name.split(":::")[-1]
            elif "/" in comp_name or "\\" in comp_name:
                comp_name = Path(comp_name).stem
                
            # Get baseline model
            base_name = row['Baseline']
            if ":::" in base_name:
                base_name = base_name.split(":::")[-1]
            elif "/" in base_name or "\\" in base_name:
                base_name = Path(base_name).stem
                
            p_values[(comp_name, base_name)] = row['P_Value']
    else:
        print(f"Warning: McNemar report not found at {mcnemar_path}.")

    # 2. Load Baseline F1-scores for each model
    baselines = {}
    b_dir_path = Path(baseline_dir)
    for m_key, m_label in models.items():
        b_path = b_dir_path / f"{baseline_prefix}_{m_key}.csv"
        if b_path.exists():
            df_base = pd.read_csv(b_path, index_col=0)
            baselines[m_label] = df_base.loc["macro avg", "f1-score"]
        else:
            print(f"Warning: Baseline report not found for {m_label} at {b_path}.")

    records = []

    # 3. Load N-Gram data
    for ng in ngram_ranges:
        for m_key, m_label in models.items():
            filename = f"ng{ng}_{m_key}.csv"
            filepath = reports_path / filename

            if filepath.exists():
                df = pd.read_csv(filepath, index_col=0)
                
                # Look up specific (Model vs Its Own Baseline) P-value
                stem = filepath.stem
                expected_baseline_stem = f"{baseline_prefix}_{m_key}"
                
                if (stem, expected_baseline_stem) in p_values:
                    p_val = p_values[(stem, expected_baseline_stem)]
                    is_sig = p_val < 0.05
                else:
                    print(f"Warning: No McNemar test found for {stem} vs {expected_baseline_stem}. Assuming significant.")
                    is_sig = True 
                
                records.append({
                    "N-Gram Range": f"1 to {ng.split('-')[1]}", 
                    "Model": m_label,
                    "Macro F1-Score": df.loc["macro avg", "f1-score"],
                    "Filename": stem,
                    "Is Significant": is_sig
                })

    if not records:
        print("No matching files found!")
        return

    results_df = pd.DataFrame(records)

    # Canvas Setup
    plt.rcParams['font.family'] = 'sans-serif'
    fig, ax = plt.subplots(figsize=(10, 6), facecolor='#F8F9FA')
    ax.set_facecolor('white')

    custom_palette = {"Linear SVM": "#2c3e50", "Logistic Regression": "#e74c3c"}
    insignificant_color = "#999999"

    # Draw Line Plot
    sns.lineplot(
        data=results_df, 
        x="N-Gram Range", 
        y="Macro F1-Score", 
        hue="Model",
        palette=custom_palette,
        marker='o',
        markersize=10,
        linewidth=3,
        ax=ax,
        zorder=3
    )

    # 4. Draw Baseline Lines
    for m_label, b_f1 in baselines.items():
        color = custom_palette[m_label]
        ax.axhline(y=b_f1, color=color, linestyle='--', linewidth=2, alpha=0.6, zorder=1)

    # 5. Annotate Points & Gray out insignificant ones
    for i, row in results_df.iterrows():
        is_best = (row['Macro F1-Score'] == results_df['Macro F1-Score'].max())
        prefix = "★ " if is_best else ""
        
        is_sig = row["Is Significant"]
        display_color = custom_palette[row["Model"]] if is_sig else insignificant_color
        
        # Overlay a gray marker if the result is not significant
        if not is_sig:
            ax.scatter(
                x=row["N-Gram Range"], 
                y=row["Macro F1-Score"], 
                color=insignificant_color, 
                s=100, 
                zorder=4
            )

        ax.text(
            x=row["N-Gram Range"],
            y=row["Macro F1-Score"] + 0.0005,
            s=f"{prefix}{row['Macro F1-Score']:.4f}",
            color=display_color,
            fontweight='bold',
            ha='center',
            va='bottom',
            fontsize=10
        )

    # Formatting & Cleanup
    ax.set_title(
        f"Performance Trend across N-Gram Ranges (Z={z_threshold})", 
        fontsize=16, fontweight='bold', pad=20
    )
    ax.set_ylabel("Macro F1-Score", fontsize=12, fontweight='bold', labelpad=10)
    ax.set_xlabel("Vocabulary Depth (N-Grams)", fontsize=12, fontweight='bold', labelpad=10)

    # Clean Spines
    for spine in ['top', 'right']:
        ax.spines[spine].set_visible(False)
    ax.spines['left'].set_color('#DDDDDD')
    ax.spines['bottom'].set_color('#DDDDDD')
    
    ax.grid(axis='both', linestyle='--', alpha=0.3, zorder=0)

    # Dynamic Y-axis scaling
    y_vals = results_df["Macro F1-Score"].tolist() + list(baselines.values())
    if y_vals:
        y_min = min(y_vals) - 0.005
        y_max = max(y_vals) + 0.005
        ax.set_ylim(y_min, y_max)

    # 6. Custom Legend Construction
    if ax.legend_:
        ax.legend_.remove()
        
    custom_handles = []
    
    # Add models to legend
    for m_label in results_df['Model'].unique():
        custom_handles.append(
            mlines.Line2D([], [], color=custom_palette[m_label], marker='o', markersize=8, label=m_label, linewidth=3)
        )
        
    # Add baselines to legend
    for m_label, b_f1 in baselines.items():
        color = custom_palette[m_label]
        custom_handles.append(
            mlines.Line2D([], [], color=color, linestyle='--', linewidth=2, alpha=0.6, label=f'{m_label} Baseline')
        )

    # Add significance marker to legend if applicable
    if not results_df["Is Significant"].all():
        custom_handles.append(
            mlines.Line2D([], [], color='white', marker='o', markerfacecolor=insignificant_color, markersize=8, label=r'Insignificant ($p \geq 0.05$)')
        )
        
    ax.legend(handles=custom_handles, title="Legend", title_fontproperties={'weight': 'bold'}, loc='best')

    plt.tight_layout()

    # Save and show
    out_dir = Path("results/figures/analysis")
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / "ngram_experiment_lines.png"

    plt.savefig(out_path, dpi=200, bbox_inches='tight')
    print(f"Saved polished line chart to: {out_path}")

    plt.show()

if __name__ == "__main__":
    plot_ngram_results_polished()





